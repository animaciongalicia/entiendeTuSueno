# ══════════════════════════════════════════════════════════════
#  EntiendetuSueño — Variables de entorno
#  Copia este archivo a .env.local y rellena los valores reales.
#  NUNCA subas .env.local al repositorio.
# ══════════════════════════════════════════════════════════════

# ── Anthropic / Claude ────────────────────────────────────────
# Obtén tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar en el interpretador (opcional, tiene fallback)
# Opciones: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-opus-4-6

# ── URL base del sitio ────────────────────────────────────────
# Solo necesario si despliegas en un dominio diferente (staging, preview)
# En producción puedes dejarlo vacío; el fallback es entiendetusueno.com
NEXT_PUBLIC_SITE_URL=https://entiendetusueno.com

# ── Google Analytics 4 ────────────────────────────────────────
# Formato: G-XXXXXXXXXX
# Obtén tu ID en https://analytics.google.com → Admin → Flujos de datos
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google AdSense ────────────────────────────────────────────
# Formato: ca-pub-XXXXXXXXXXXXXXXX
# Obtén tu publisher ID en https://adsense.google.com → Cuenta → Información de cuenta
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# ── Supabase ──────────────────────────────────────────────────
# Obtén los valores en https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────
# Obtén las claves en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret generado al crear el endpoint en https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (emails transaccionales y newsletter) ──────────────
# Obtén tu clave en https://resend.com/api-keys
RESEND_API_KEY=re_...
# Dirección de envío verificada en Resend (ej. newsletter@tudominio.com)
RESEND_FROM_EMAIL=newsletter@entiendetusueno.com

# ── Integraciones opcionales ──────────────────────────────────
# Webhook de Make.com para automatizar la gestión de suscriptores
# MAKE_NEWSLETTER_WEBHOOK_URL=https://hook.eu2.make.com/...
